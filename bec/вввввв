<!DOCTYPE html>
<html>
<head>
    <title>Карта України (GeoJSON)</title>
    <script src="https://d3js.org/d3.v7.min.js"></script>
    <script src="https://d3js.org/d3-geo-projection.v4.min.js"></script>
    <style>
        body {
            background-color: #0a0e17;
            color: #e0e0e0;
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
        }
        #map {
            width: 1200px;
            height: 900px;
            margin: 20px auto;
            background-color: #0a0e17;
            border: 1px solid #2A2D31;
        }
        .region {
            fill: #2A2D31;
            stroke: #141921;
            stroke-width: 0.5;
            transition: fill 0.2s;
        }
        .region:hover {
            fill: #3a4a6b;
            cursor: pointer;
        }
        #tooltip {
            position: absolute;
            padding: 10px;
            background: rgba(20, 25, 33, 0.95);
            color: #ffffff;
            border-radius: 4px;
            pointer-events: none;
            font-size: 14px;
            font-family: Arial;
            display: none;
            border: 1px solid #3a4a6b;
            box-shadow: 0 0 10px rgba(0,0,0,0.5);
            max-width: 300px;
        }
        h1 {
            text-align: center;
            color: #e0e0e0;
            margin: 0;
            padding: 20px 0;
        }
    </style>
</head>
<body>
    <h1>Карта України (full_area_ukraine_geo_v07_08_2024)</h1>
    <div id="map"></div>
    <div id="tooltip"></div>

    <script>
        fetch('gadm41_UKR_2.json')
            .then(response => response.json())
            .then(data => {
                const width = 1200;
                const height = 900;

                const svg = d3.select("#map")
                    .append("svg")
                    .attr("width", width)
                    .attr("height", height)
                    .style("background-color", "#0a0e17");

                // Оптимальна проекція для України (CRS84)
                const projection = d3.geoMercator()
                    .center([31.1656, 48.3794]) // Центр України
                    .scale(3800) /* Масштаб для великого розміру */
                    .translate([width / 2, height / 2]);

                const path = d3.geoPath().projection(projection);

                // Відображення об'єктів
                svg.selectAll("path")
                    .data(data.features)
                    .enter()
                    .append("path")
                    .attr("class", "region")
                    .attr("d", path)
                    .on("mouseover", function(event, d) {
                        d3.select(this).attr("fill", "#3a4a6b");
                        const tooltip = d3.select("#tooltip");
                        
                        // Генерація підказки з доступними властивостями
                        let tooltipHtml = "<div style='font-weight:bold'>";
                        if (d.properties.name) tooltipHtml += d.properties.name;
                        if (d.properties.NAME_1) tooltipHtml += ` (${d.properties.NAME_1})`;
                        tooltipHtml += "</div>";
                        
                        // Додаткові властивості (якщо є)
                        for (const [key, value] of Object.entries(d.properties)) {
                            if (key !== "name" && key !== "NAME_1") {
                                tooltipHtml += `<div><small>${key}: ${value}</small></div>`;
                            }
                        }

                        tooltip.html(tooltipHtml)
                            .style("left", (event.pageX + 15) + "px")
                            .style("top", (event.pageY - 15) + "px")
                            .style("display", "block");
                    })
                    .on("mouseout", function() {
                        d3.select(this).attr("fill", "#2A2D31");
                        d3.select("#tooltip").style("display", "none");
                    });

                // Автоматичний підбір підписів (якщо є назви)
                if (data.features.some(d => d.properties.name)) {
                    svg.selectAll("text")
                        .data(data.features.filter(d => d.properties.name))
                        .enter()
                        .append("text")
                        .attr("x", d => path.centroid(d)[0])
                        .attr("y", d => path.centroid(d)[1])
                        .text(d => d.properties.name)
                        .attr("font-size", "10px")
                        .attr("fill", "#e0e0e0")
                        .attr("text-anchor", "middle");
                }
            })
            .catch(error => {
                console.error("Помилка завантаження даних:", error);
                d3.select("#map").html("<p style='color:red'>Помилка завантаження даних. Перевірте консоль для деталей.</p>");
            });
    </script>
</body>
</html>